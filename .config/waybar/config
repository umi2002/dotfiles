[
{
    "name": "top",
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 35, // Waybar height (to be removed for auto height)
    "width": 1536, // Waybar width
    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": ["wlr/workspaces", ],
    "modules-center": [ ],
    "modules-right": ["idle_inhibitor", "clock", ],
    // Modules configuration
    "wlr/workspaces": {
        "on-click": "activate",
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}. {icon}",
        "format-icons": {
            "1":"ˇ░Ö» ",
            "2":"´ëĘ ",
            "3":"´äí ",
            "4":"´ć╝ ",
            "5":"´üÁ ",
            "8":"ˇ░ç« ",
            "9":"´ć╝ ",
            "10":"´ÇĽ",
            "urgent":"´ü¬ ",
            "focused":"´ćĺ ",
            "default":"´äĹ "
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        }
    },
    "clock": {
        "timezone": "Canada/Eastern",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%Y-%m-%d, %H:%M:%S}",
    },
},

{
    "name": "bottom",
    "layer": "top", // Waybar at top layer
    "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 35, // Waybar height (to be removed for auto height)
    "width": 1536, // Waybar width
    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": [ ],
    "modules-center": ["image/album-art", "mpris", "pulseaudio", ],
    "modules-right": ["keyboard-state", "hyprland/language", ],
    // Modules configuration
    "image/album-art": {
         "exec":"~/.config/waybar/custom/spotify/album_art.sh",
         "size": 32,
         "interval": 30,  
    },
    "mpris": {
        "format": "{player_icon} {dynamic} {status_icon}",
        "format-paused": "{player_icon} <i>{dynamic}</i> {status_icon}",
        "player-icons": {
            "default": "´Çü",
            "spotify": "´ć╝",
        },
        "status-icons": {
            "playing": "´Őő",
            "paused": "´ůä"
        },
        // "ignored-players": ["firefox"]
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
        "format-bluetooth-muted": "{volume}% {icon}´Őö {format_source}",
        "format-muted": "{volume}% {icon} {format_source}",
        "format-source": "{volume}% ´ä░",
        "format-source-muted": "{volume}% ´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "on-click": "amixer set Master toggle",
        "on-click-middle": "pavucontrol",
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "´Çú ",
            "unlocked": "´éť "
        }
    },
    "hyprland/language": {
        "format": "{}",
        "on-click": "hyprctl switchxkblayout razer-razer-blackwidow-v3 next",
    },
}
]


