[
{
    "name": "top",
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 35, // Waybar height (to be removed for auto height)
    "width": 1536, // Waybar width
    "spacing": 0, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": ["wlr/workspaces", "tray", ],
    "modules-center": [ ],
    "modules-right": ["idle_inhibitor", "clock", ],
    // Modules configuration
    "wlr/workspaces": {
        "on-click": "activate",
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}. {icon}",
        "format-icons": {
            "1":"¾░Ö» ",
            "2":"  ",
            "3":"  ",
            "4":"  ",
            "5":"  ",
            "8":"¾░ç« ",
            "9":"´å╝ ",
            "10":"´Çò",
            "urgent":"´ü¬ ",
            "focused":"´åÆ ",
            "default":"´äæ "
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        }
    },
    "clock": {
        "timezone": "Canada/Eastern",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%Y-%m-%d, %H:%M:%S}",
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
},

{
    "name": "bottom",
    "layer": "top", // Waybar at top layer
    "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 35, // Waybar height (to be removed for auto height)
    "width": 1536, // Waybar width
    "spacing": 0, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": ["disk", "memory", "cpu", "network", ],
    "modules-center": ["image/album-art", "mpris", ],
    "modules-right": ["pulseaudio", "keyboard-state", "hyprland/language", ],
    // Modules configuration
    "disk": {
        "interval": 30,
        "format": "{percentage_used}% {total}¾░Æï",
        "path": "/"
    },
    "memory": {
        "format": "{}% {total}GiB´âë"
    },
    "cpu": {
        "format": "{usage}%´ïø",
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%)´ç½",
        "format-ethernet": "{ipaddr}´ç½",
        "tooltip-format": "{ifname} via {gwaddr}´ç½",
        "format-linked": "{ifname} (No IP)´ç½",
        "format-disconnected": "DisconnectedÔÜá",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "image/album-art": {
         "exec":"~/.config/waybar/custom/spotify/album_art.sh",
         "size": 32,
         "interval": 30,  
    },
    "mpris": {
        "format": "{player_icon} {artist} ¾░Äê {title} [{length}] {status_icon}",
        "format-paused": "{player_icon} <i>{artist} ¾░Äê {title} [{length}] </i> {status_icon}",
        "player-icons": {
            "default": "´Çü",
            "spotify": "´å╝",
            },
        "status-icons": {
            "playing": "´èï",
            "paused": "´àä"
            },
        // "ignored-players": ["firefox"]
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}´èö {format_source}",
        "format-bluetooth-muted": "{volume}% {icon}´èö {format_source}",
        "format-muted": "{volume}% {icon} {format_source}",
        "format-source": "{volume}% ´ä░",
        "format-source-muted": "{volume}% ´ä▒",
        "format-icons": {
            "headphone": "´ÇÑ",
            "hands-free": "´ûÉ",
            "headset": "´ûÉ",
            "phone": "´éò",
            "portable": "´éò",
            "car": "´å╣",
            "default": ["´Çª", "´Çº", "´Ç¿"]
        },
        "on-click": "amixer set Master toggle",
        "on-click-middle": "pavucontrol",
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "´Çú ",
            "unlocked": "´é£ "
        }
    },
    "hyprland/language": {
        "format": "{}",
        "on-click": "hyprctl switchxkblayout razer-razer-blackwidow-v3 next",
    },
}
]


